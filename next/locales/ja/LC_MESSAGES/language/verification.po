msgstr ""

#: ../../language/verification.md:16
msgid ""
"The following package gives a compact overview of how verification in "
"MoonBit fits together. It shows:"
msgstr ""

#: ../../language/verification.md:19
msgid "package-level proof enablement"
msgstr ""

#: ../../language/verification.md:20
msgid "logic-side predicates in `.mbtp`"
msgstr ""

#: ../../language/verification.md:21
msgid "a program-side function in `.mbt`"
msgstr ""

#: ../../language/verification.md:22
msgid "preconditions and postconditions"
msgstr ""

#: ../../language/verification.md:23
msgid "loop invariants and `proof_yield`"
msgstr ""

#: ../../language/verification.md:24
msgid "local `proof_assert` steps"
msgstr ""

#: ../../language/verification.md:25
msgid "`proof_reasoning` as a proof-oriented explanation of the loop"
msgstr ""

#: ../../language/verification.md:27
msgid "First, enable proofs for the package:"
msgstr ""

#: ../../language/verification.md:29
msgid ""
"options(\n"
"  \"proof-enabled\": true,\n"
")\n"
msgstr ""

#: ../../language/verification.md:33
msgid "Then define the logic-side specification in `.mbtp`:"
msgstr ""

#: ../../language/verification.md:35 ../../language/verification.md:277
msgid ""
"predicate in_bounds(xs : FixedArray[Int], i : Int) {\n"
"  (0 <= i) && (i < xs.length())\n"
"}\n"
"\n"
"predicate sorted(xs : FixedArray[Int]) {\n"
"  ∀ i : Int, ∀ j : Int,\n"
"    in_bounds(xs, i) && in_bounds(xs, j) && (i <= j) →\n"
"      xs[i] <= xs[j]\n"
"}\n"
"\n"
"predicate binary_search_ok(xs : FixedArray[Int], key : Int, result : "
"Option[Int]) {\n"
"  match result {\n"
"    None => ∀ i : Int, in_bounds(xs, i) → xs[i] != key\n"
"    Some(result) => in_bounds(xs, result) && xs[result] == key\n"
"  }\n"
"}\n"
msgstr ""

#: ../../language/verification.md:41
msgid "Finally, implement the executable function in `.mbt`:"
msgstr ""

#: ../../language/verification.md:43
msgid ""
"pub fn binary_search(\n"
"  xs : FixedArray[Int],\n"
"  key : Int,\n"
") -> Int? where {\n"
"  proof_require: sorted(xs),\n"
"  proof_ensure: result => binary_search_ok(xs, key, result),\n"
"} {\n"
"  for i = 0, j = xs.length(); i < j; {\n"
"    let h = i + (j - i) / 2\n"
"    if xs[h] < key {\n"
"      proof_assert ∀ idx : Int,\n"
"        (0 <= idx) && (idx < h + 1) → xs[idx] < key\n"
"      continue h + 1, j\n"
"    } else if key < xs[h] {\n"
"      proof_assert ∀ idx : Int,\n"
"        (h <= idx) && (idx < xs.length()) → key < xs[idx]\n"
"      continue i, h\n"
"    } else {\n"
"      proof_assert xs[h] == key\n"
"      break Some(h)\n"
"    }\n"
"  } nobreak {\n"
"    None\n"
"  } where {\n"
"    proof_invariant: 0 <= i,\n"
"    proof_invariant: i <= j,\n"
"    proof_invariant: j <= xs.length(),\n"
"    proof_invariant: ∀ idx : Int, (0 <= idx) && (idx < i) → xs[idx] < "
"key,\n"
"    proof_invariant: ∀ idx : Int, (j <= idx) && (idx < xs.length()) → key"
" < xs[idx],\n"
"    proof_yield: res => binary_search_ok(xs, key, res),\n"
"    proof_reasoning: (\n"
"      #| The loop maintains a candidate window `[i, j)`.\n"
"      #| Every index before `i` is known to hold a value `< key`, and "
"every\n"
"      #| index from `j` onward is known to hold a value `> key`.\n"
"      #|\n"
"      #| At midpoint `h` there are three cases:\n"
"      #|   - `xs[h] < key`: move the left boundary to `h + 1`\n"
"      #|   - `key < xs[h]`: move the right boundary to `h`\n"
"      #|   - otherwise, the element at `h` is equal to `key`\n"
"      #|\n"
"      #| If the loop exits normally, the exclusion invariants cover the "
"whole\n"
"      #| array, so no index can contain `key`.\n"
"    ),\n"
"  }\n"
"}\n"
msgstr ""

